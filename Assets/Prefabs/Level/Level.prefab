  dialogue:
    dialogueLines:
    - character:
        name: Bob The Baker
        icon: {fileID: 7095889761123657688, guid: 4b53ffc3741f76a43affb8f5bf8b4784, type: 3}
      line: You gotta help us...
    - character:
        name: Bob The Baker
        icon: {fileID: 2546757870057634713, guid: 9400ac965be7e534ca8083b6243ae494, type: 3}
      line: What do you need help with?
    - character:
        name: Bob The Baker
        icon: {fileID: 7095889761123657688, guid: 4b53ffc3741f76a43affb8f5bf8b4784, type: 3}
      line: Those monsters keep getting closer while leaving the forests... It's
        only a matter of time until they scare off every last of my customers!
    - character:
        name: Player
        icon: {fileID: 2546757870057634713, guid: 9400ac965be7e534ca8083b6243ae494, type: 3}
      line: Leave it to me.
